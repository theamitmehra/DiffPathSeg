{
  "seed": 42,
  "backend": "ldm",
  "output_dir": "outputs",
  "image_size": 256,
  "num_normal_images": 20,
  "num_generate_attempts": 80,
  "max_curated_samples": 40,
  "batch_size": 4,
  "quality_thresholds": {
    "min_iou": 0.45,
    "min_area_ratio": 0.003,
    "max_area_ratio": 0.25
  },
  "longitudinal": {
    "enable": true,
    "timesteps": 5,
    "severity_min": 0.1,
    "severity_max": 0.9
  },
  "qc": {
    "backend": "torch",
    "latent_size": 32
  },
  "ldm": {
    "model_id": "runwayml/stable-diffusion-inpainting",
    "device": "cuda",
    "guidance_scale": 8.0,
    "num_inference_steps": 40,
    "strength": 0.92
  },
  "text_prompts": [
    "small peripheral lung nodule",
    "focal liver lesion with irregular border",
    "subtle white matter hyperintensity"
  ]
}
